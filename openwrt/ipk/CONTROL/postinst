#!/bin/sh
[ -z "${IPKG_INSTROOT}" ] || exit 0

# Auto-load module on boot
echo "8852bu rtw_power_mgnt=0 rtw_ips_mode=0" > /etc/modules.d/rtl8852bu

# Load module now
insmod 8852bu rtw_power_mgnt=0 rtw_ips_mode=0 2>/dev/null
sleep 2

# Detect and create UCI config if not already present
. /lib/wifi/realtek.sh

# Ensure wwan network exists
uci -q get network.wwan >/dev/null || {
    uci set network.wwan=interface
    uci set network.wwan.proto='dhcp'
    uci commit network
}

echo "RTL8852BU driver installed."
echo "Configure the adapter in LuCI under Network -> Wireless."
